    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1"
  }
