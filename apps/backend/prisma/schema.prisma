generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  elo      Int    @default(1200)
  matches  Match[]
}

model Match {
  id        String   @id @default(uuid())
  status    String   @default("WAITING")
  problemId String
  winnerId  String?
  createdAt DateTime @default(now())
  players   User[]
}
